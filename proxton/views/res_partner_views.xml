<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add tax_id field to partner form view -->
    <record id="view_partner_form_inherit_proxton_tax_id" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.proxton.tax_id</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_vat_placeholder']" position="before">
                <field name="tax_id" invisible="country_code != 'SK'"/>
            </xpath>
        </field>
    </record>

    <!-- Add tax_id field to partner list view -->
    <record id="view_partner_tree_inherit_proxton_tax_id" model="ir.ui.view">
        <field name="name">res.partner.list.inherit.proxton.tax_id</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="before">
                <field name="tax_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
