<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add rounded_duration to work entry list view -->
    <record id="hr_work_entry_view_tree_inherit_proxton" model="ir.ui.view">
        <field name="name">hr.work.entry.list.inherit.proxton</field>
        <field name="model">hr.work.entry</field>
        <field name="inherit_id" ref="hr_work_entry.hr_work_entry_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='duration']" position="after">
                <field name="duration_rounded" widget="float_time" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add rounded_duration to work entry form view -->
    <record id="hr_work_entry_view_form_inherit_proxton" model="ir.ui.view">
        <field name="name">hr.work.entry.form.inherit.proxton</field>
        <field name="model">hr.work.entry</field>
        <field name="inherit_id" ref="hr_work_entry.hr_work_entry_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='duration']" position="after">
                <field name="duration_rounded" widget="float_time" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
