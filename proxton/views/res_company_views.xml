<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add tax_id field to company form view -->
    <record id="view_company_form_inherit_proxton_tax_id" model="ir.ui.view">
        <field name="name">res.company.form.inherit.proxton.tax_id</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_registry']" position="after">
                <field name="tax_id" invisible="country_code != 'SK'"/>
            </xpath>
        </field>
    </record>
</odoo>
